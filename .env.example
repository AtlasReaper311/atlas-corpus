# atlas-corpus configuration. Everything except CORPUS_SECRET has the
# same default baked into app/config.py and docker-compose.yml.

# REQUIRED, fail-closed: generate with
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
CORPUS_SECRET=

# Strongly recommended: unauthenticated GitHub allows 60 requests/hour
# and a full ingest uses more. Fine-grained PAT, public repo read only.
GITHUB_TOKEN=

# Ollama on the host; extra_hosts maps this on native Linux.
OLLAMA_HOST=http://host.docker.internal:11434
EMBED_MODEL=nomic-embed-text
EMBED_BATCH_SIZE=16

# Chroma inside this compose stack.
CHROMA_HOST=chromadb
CHROMA_PORT=8000
COLLECTION_NAME=atlas_corpus

# Sources
GITHUB_OWNER=AtlasReaper311
EXCLUDE_REPOS=AtlasReaper311
SITE_REPO=atlas-systems
CASE_STUDY_PREFIX=work/
ARTICLE_PREFIX=writing/
EXTRA_FILES=atlas-infra:docs/decisions.md:decision
DOCS_DIR=/srv/docs

# Chunking (word-based, approximates the 512/64 token spec)
CHUNK_WORDS=512
CHUNK_OVERLAP_WORDS=64

# Public search protections
TOP_K_DEFAULT=5
TOP_K_MAX=10
QUERY_MAX_CHARS=500
RATE_LIMIT_PER_HOUR=60
ALLOWED_ORIGINS=https://atlas-systems.uk,https://www.atlas-systems.uk,http://localhost:8788

# 0 disables timer refresh; the push trigger is the primary mechanism.
REFRESH_INTERVAL_SECONDS=0

LOG_LEVEL=INFO
